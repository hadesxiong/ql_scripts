# output 保留目录结构，忽略所有产出文件
output/**
!output/**/.gitkeep

# Python 缓存、虚拟环境
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
*.bak

# JS / TS 依赖与编译产物
node_modules/
dist/
*.log
npm-debug.log
tsconfig.tsbuildinfo

# Shell 临时文件
*.tmp
*.bak
*.swp
.DS_Store

# 本地真实密钥/环境（仅允许各脚本内 config.tpl.env 提交）
.env
*.secret
secret.json
config.local.sh